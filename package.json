{
  "name": "@suntory-n-water/cc-spinner",
  "description": "CLI tool to distribute and apply spinnerVerbs themes for Claude Code",
  "type": "module",
  "version": "0.0.4",
  "license": "MIT",
  "homepage": "https://github.com/Suntory-N-Water/cc-spinner#readme",
  "bugs": {
    "url": "https://github.com/Suntory-N-Water/cc-spinner/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Suntory-N-Water/cc-spinner.git"
  },
  "keywords": [
    "claude-code",
    "spinner",
    "spinner-verbs",
    "cli",
    "theme"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cc-spinner": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node --minify",
    "prepublishOnly": "bun run build",
    "test": "AGENT=1 bun test --bail=2",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "biome lint .",
    "lint:unsafe-fix": "biome lint --write --unsafe .",
    "lint:ai": "biome lint --reporter=github . 2>&1 | { grep '^::' || true; }",
    "type-check": "tsc --noEmit",
    "type-check:ai": "tsc --noEmit --pretty false",
    "ai-check": "bun run format && bun run lint:ai && bun run type-check:ai"
  },
  "knip": {
    "entry": [
      "src/index.ts",
      "tests/**/*.test.ts"
    ],
    "ignoreDependencies": [
      "@changesets/cli"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@types/bun": "1.3.10",
    "@types/node": "25.4.0",
    "knip": "5.86.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "commander": "14.0.3",
    "picocolors": "1.1.1",
    "valibot": "1.2.0"
  }
}
