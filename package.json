{
  "name": "cc-spinner",
  "type": "module",
  "private": true,
  "version": "0.0.1",
  "bin": {
    "cc-spinner": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node",
    "prepublishOnly": "bun run build",
    "test": "AGENT=1 bun test --bail=2",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "biome lint .",
    "lint:unsafe-fix": "biome lint --write --unsafe .",
    "lint:ai": "biome lint --reporter=github . 2>&1 | { grep '^::' || true; }",
    "type-check": "tsc --noEmit",
    "type-check:ai": "tsc --noEmit --pretty false",
    "ai-check": "bun run format && bun run lint:ai && bun run type-check:ai"
  },
  "knip": {
    "entry": [
      "src/index.ts",
      "src/validate-themes.ts",
      "tests/**/*.test.ts"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/bun": "1.3.10",
    "@types/node": "25.4.0",
    "knip": "5.86.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "commander": "14.0.3",
    "picocolors": "1.1.1",
    "valibot": "1.2.0"
  }
}
