{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "mode", "verbs"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mode": {
      "type": "string",
      "enum": ["replace", "append"]
    },
    "verbs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  }
}
